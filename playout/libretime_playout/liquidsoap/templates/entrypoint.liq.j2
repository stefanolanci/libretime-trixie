# THIS FILE IS AUTO GENERATED. PLEASE DO NOT EDIT!
###########################################################
# The ignore() lines are to squash unused variable warnings

{% macro harbor_transport(input) -%}
{%- if input.secure -%}
http.transport.ssl(
  certificate={{ config.liquidsoap.harbor_ssl_certificate | quote }},
  key={{ config.liquidsoap.harbor_ssl_private_key | quote }}{% if config.liquidsoap.harbor_ssl_password %},
  password={{ config.liquidsoap.harbor_ssl_password | quote }}{% endif %}
)
{%- else -%}
http.transport.unix
{%- endif -%}
{%- endmacro %}

# Inputs
input_main_mount = {{ config.stream.inputs.main.mount | quote }}
input_main_port = {{ config.stream.inputs.main.port }}
input_main_transport = {{ harbor_transport(config.stream.inputs.main) }}
input_show_mount = {{ config.stream.inputs.show.mount | quote }}
input_show_port = {{ config.stream.inputs.show.port }}
input_show_transport = {{ harbor_transport(config.stream.inputs.show) }}

# Settings (LS 2.3 syntax: `settings.path.to.key := value`)
{% if paths.log_filepath is defined -%}
settings.log.file.path := "{{ paths.log_filepath }}"
{%- else -%}
settings.log.file.path := ""
{%- endif %}

settings.server.telnet := true
settings.server.telnet.bind_addr := {{ config.liquidsoap.server_listen_address | quote }}
settings.server.telnet.port := {{ config.liquidsoap.server_listen_port }}

settings.harbor.bind_addrs := ["{{ config.liquidsoap.harbor_listen_address | join('", "') }}"]

station_name = interactive.string("station_name", {{ info.station_name | quote }})

message_offline = interactive.string("message_offline", {{ preferences.message_offline | quote }})
message_format = interactive.string("message_format", {{ preferences.message_format.value | quote }})
input_fade_transition = interactive.float("input_fade_transition", {{ preferences.input_fade_transition }})

# Idle input for the relay http source (lavfi anullsrc or a local media path).
http_idle_initial_path = {{ http_idle_initial_path | quote }}

%include "{{ paths.lib_filepath }}"

{% include "outputs.liq.j2" %}

gateway("started")
