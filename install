#!/usr/bin/env bash

set -eu -o pipefail

red='\e[0;31m'
yellow='\e[1;33m'
cyan='\e[0;36m'
reset='\e[0m'

info() {
  printf "${cyan}info: $*${reset}\n"
}

warning() {
  printf >&2 "${yellow}warning: $*${reset}\n"
}

error() {
  printf >&2 "${red}error: $*${reset}\n"
  exit 1
}

section() {
  text="$*"
  printf -v bar '═%.0s' {1..78}
  printf -v fill ' %.0s' {1..76}
  printf "$cyan"
  printf '╔%s╗\n' "$bar"
  printf '║ %s ║\n' "${text}${fill:${#text}}"
  printf '╚%s╝\n' "$bar"
  printf "$reset"
}

banner() {
  printf "${cyan}"
  cat << EOF

  ██╗     ██╗██████╗ ██████╗ ███████╗████████╗██╗███╗   ███╗███████╗
  ██║     ██║██╔══██╗██╔══██╗██╔════╝╚══██╔══╝██║████╗ ████║██╔════╝
  ██║     ██║██████╔╝██████╔╝█████╗     ██║   ██║██╔████╔██║█████╗
  ██║     ██║██╔══██╗██╔══██╗██╔══╝     ██║   ██║██║╚██╔╝██║██╔══╝
  ███████╗██║██████╔╝██║  ██║███████╗   ██║   ██║██║ ╚═╝ ██║███████╗
  ╚══════╝╚═╝╚═════╝ ╚═╝  ╚═╝╚══════╝   ╚═╝   ╚═╝╚═╝     ╚═╝╚══════╝

EOF
  printf "${reset}"
}

SCRIPT_DIR="$( cd "$( dirname "$0")" && pwd)"
# Make every relative path (make VERSION, make -C legacy, ...) stable regardless
# of the caller's working directory.
cd "$SCRIPT_DIR"

version() {
  if [ ! -f "$SCRIPT_DIR/VERSION" ]; then
    make VERSION > /dev/null
  fi
  echo "LibreTime Version $(cat "$SCRIPT_DIR/VERSION")"
  exit 0
}

usage() {
  cat >&2 << EOF
Usage: $0 [option]... [public_url]

  Install LibreTime on the system.

Options:

  --user USER, -u USER          User used to run LibreTime.
  --listen-port PORT, -p PORT   Listen port for LibreTime.
  --storage-path PATH, -s PATH  Storage path for LibreTime.

  --in-place, -i                Install LibreTime in place.

  --no-setup-icecast            Do not setup Icecast.
  --no-setup-postgresql         Do not setup Postgresql.
  --no-setup-rabbitmq           Do not setup RabbitMQ.
  --setup-fail2ban              Install LibreTime fail2ban filters and jails
                                (Harbor, Icecast admin, nginx login).
  --no-setup-fail2ban           Do not configure fail2ban (default).

  --no-https-auto               Do not run Certbot / reverse proxy / Icecast TLS,
                                even if public_url starts with https://

  --wizard                      Interactive prompts (HTTP vs HTTPS, Certbot email, …).
                                Do not pass a positional public_url together with --wizard.

Environment variables:

  Advanced options can be changed using environment variables (flags will take
  precedence over environment variables).

EOF

  while IFS= read -r line; do
    if [[ "$line" == \#* ]]; then
      line="${cyan}${line}${reset}"
    fi

    # Pretty print variable definition
    line=$(echo "$line" | sed -E 's/=\$\{[A-Z_]+\:-(.*)\}/=\1/g')

    printf "  ${line}\n"
  done <<< "$(grep -A1 '^# >' "$0")"
}

# Wizard helper: read a clean host/FQDN from the interactive TTY.
# Defensively strips any scheme, trailing path, and explicit port the user may
# paste out of habit, with short educational warnings. The caller only gets the
# bare hostname (IPv4, FQDN, or IPv6 literal in brackets) via WIZARD_CLEAN_HOST.
#
# Args:
#   $1  mode         "http" or "https"
#   $2  wiz_tty      interactive TTY device (usually /dev/tty)
#   $3  listen_port  LIBRETIME_LISTEN_PORT (used only in warnings for HTTP mode)
wizard_read_clean_host() {
  local mode="$1" wiz_tty="$2" listen_port="$3"
  local host_in=""
  WIZARD_CLEAN_HOST=""
  while [[ -z "$WIZARD_CLEAN_HOST" ]]; do
    printf "Host: " >"$wiz_tty"
    read -r host_in <"$wiz_tty" || true
    host_in="$(printf '%s' "$host_in" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
    if [[ -z "$host_in" ]]; then
      warning "Host cannot be empty."
      continue
    fi

    # Strip scheme if present.
    local had_scheme=false
    case "$host_in" in
      http://*)
        [[ "$mode" == "https" ]] && warning "You chose HTTPS mode: dropping the http:// prefix. Pick option 1 if you need plain HTTP."
        host_in="${host_in#http://}"; had_scheme=true ;;
      https://*)
        [[ "$mode" == "http" ]] && warning "You chose HTTP mode: dropping the https:// prefix. Pick option 2 if you need HTTPS."
        host_in="${host_in#https://}"; had_scheme=true ;;
      http:/*)  host_in="${host_in#http:/}";  had_scheme=true ;;
      https:/*) host_in="${host_in#https:/}"; had_scheme=true ;;
      http:*)   host_in="${host_in#http:}";   had_scheme=true ;;
      https:*)  host_in="${host_in#https:}";  had_scheme=true ;;
    esac
    if $had_scheme; then
      info "Scheme is added automatically — do not type ${yellow}${mode}://${reset}."
    fi

    # Strip a trailing path if present.
    if [[ "$host_in" == */* ]]; then
      warning "Paths are not accepted here — dropping /${host_in#*/}"
      host_in="${host_in%%/*}"
    fi

    # Detect and strip an explicit port (IPv6-bracketed form first).
    local typed_port=""
    if [[ "$host_in" == '['*']'* ]]; then
      if [[ "$host_in" =~ ^(\[[^\]]+\]):([0-9]+)$ ]]; then
        host_in="${BASH_REMATCH[1]}"
        typed_port="${BASH_REMATCH[2]}"
      fi
    elif [[ "$host_in" =~ ^([^:]+):([0-9]+)$ ]]; then
      host_in="${BASH_REMATCH[1]}"
      typed_port="${BASH_REMATCH[2]}"
    fi
    if [[ -n "$typed_port" ]]; then
      if [[ "$mode" == "http" ]]; then
        warning "Port :${typed_port} ignored — the wizard uses the Nginx listen port :${listen_port}."
        if [[ "$typed_port" != "$listen_port" ]]; then
          warning "To bind port ${typed_port} instead, abort and rerun: ${cyan}./install --wizard --listen-port ${typed_port}${reset}"
        fi
      else
        warning "Port :${typed_port} ignored — public HTTPS is always served on 443."
      fi
    fi

    if [[ -z "$host_in" ]]; then
      warning "Host is empty after cleanup — please type again."
      continue
    fi
    if [[ "$host_in" =~ [[:space:]] ]]; then
      warning "Host cannot contain whitespace — please type again."
      continue
    fi

    WIZARD_CLEAN_HOST="$host_in"
  done
}

# Interactive wizard. Sets LIBRETIME_PUBLIC_URL, LIBRETIME_CERTBOT_EMAIL, etc.
run_install_wizard() {
  local wiz_tty=/dev/tty
  if [[ ! -r "$wiz_tty" ]] || [[ ! -w "$wiz_tty" ]]; then
    error "--wizard requires an interactive terminal (TTY). For non-interactive installs use: $0 https://your.domain"
  fi

  section "Guided setup"
  printf "%b\n" "${yellow}Choose how users will reach LibreTime (browser / apps).${reset}"
  printf "This wizard covers the most common setups. For advanced options (custom ports, storage path,\n"
  printf "in-place install, skipping Icecast/PostgreSQL/RabbitMQ, etc.) abort and run ${cyan}$0 --help${reset}.\n"
  printf "\n"
  printf "  ${cyan}1${reset})  Standard ${yellow}HTTP${reset} — no TLS certificate for the web UI.\n"
  printf "      Typical for LAN, a private VPN, or while public DNS is not ready yet.\n"
  printf "      You will type just the host: ${cyan}192.168.1.10${reset} or ${cyan}radio.example.org${reset}.\n"
  printf "      Nginx binds the app on the internal listen port ${yellow}%s${reset}.\n" "$LIBRETIME_LISTEN_PORT"
  printf "      To pick a different listen port, abort and rerun with ${yellow}--listen-port PORT${reset}.\n"
  printf "      Icecast streams on ${yellow}8000${reset} (if enabled); live encoders reach Harbor on ${yellow}8001${reset}/${yellow}8002${reset}.\n"
  printf "\n"
  printf "  ${cyan}2${reset})  ${yellow}HTTPS${reset} — public Nginx on ${yellow}80${reset}/${yellow}443${reset} with a Let's Encrypt certificate.\n"
  printf "      Requires a ${cyan}FQDN${reset} with public DNS (A/AAAA) pointing at this machine and\n"
  printf "      ports ${yellow}80${reset}/${yellow}443${reset} reachable from the Internet for certificate validation.\n"
  printf "      You will type just the FQDN: ${cyan}radio.example.org${reset}.\n"
  printf "      Public Nginx reverse-proxies to the internal app on port ${yellow}%s${reset}.\n" "$LIBRETIME_LISTEN_PORT"
  printf "      To pick a different internal port, abort and rerun with ${yellow}--listen-port PORT${reset}.\n"
  printf "      Icecast: ${yellow}8000${reset} (plain HTTP, legacy clients) and ${yellow}8443${reset} (HTTPS, TLS bundle\n"
  printf "      auto-built from the Let's Encrypt certificate); Harbor stays on ${yellow}8001${reset}/${yellow}8002${reset}.\n"
  printf "\n"
  printf "  ${cyan}3${reset})  Exit without installing\n"
  printf "\n"

  local mode=""
  while [[ ! "$mode" =~ ^[123]$ ]]; do
    printf "Choice [1-3]: " >"$wiz_tty"
    read -r mode <"$wiz_tty" || true
    mode="${mode//[[:space:]]/}"
  done

  if [[ "$mode" == "3" ]]; then
    info "exiting at user request."
    exit 0
  fi

  if [[ "$mode" == "1" ]]; then
    LIBRETIME_HTTPS_AUTO=false
    printf "\n%b\n" "${cyan}Public host:${reset}"
    printf "Enter the LAN IP, hostname, or FQDN clients will use. Do not type a scheme or a port.\n"
    printf "Example: ${cyan}$(hostname -f 2>/dev/null || echo radio.example.org)${reset}\n"
    wizard_read_clean_host "http" "$wiz_tty" "$LIBRETIME_LISTEN_PORT"
    LIBRETIME_PUBLIC_URL="http://${WIZARD_CLEAN_HOST}:${LIBRETIME_LISTEN_PORT}"
    LIBRETIME_CERTBOT_EMAIL=""
    info "Public URL: ${LIBRETIME_PUBLIC_URL}"
    info "HTTP mode — automatic Certbot will not run."
  else
    LIBRETIME_HTTPS_AUTO=true
    printf "\n%b\n" "${cyan}Public FQDN:${reset}"
    printf "Enter the fully-qualified domain name clients will use. Do not type a scheme or a port.\n"
    printf "Example: ${cyan}radio.example.org${reset}\n"
    wizard_read_clean_host "https" "$wiz_tty" "$LIBRETIME_LISTEN_PORT"
    LIBRETIME_PUBLIC_URL="https://${WIZARD_CLEAN_HOST}"
    if [[ ! "${LIBRETIME_PUBLIC_URL}" =~ ^https://[^/:?#]+ ]]; then
      error "invalid HTTPS URL: ${LIBRETIME_PUBLIC_URL}"
    fi
    info "Public URL: ${LIBRETIME_PUBLIC_URL}"

    printf "\n%b\n" "${cyan}Email for the Let's Encrypt (Certbot) account:${reset}"
    printf "Used for renewal notices. Leave empty (not recommended) to use --register-unsafely-without-email.\n"
    local em_default="${LIBRETIME_CERTBOT_EMAIL:-}"
    if [[ -n "$em_default" ]]; then
      printf "Email [${yellow}%s${reset}]: " "$em_default" >"$wiz_tty"
    else
      printf "Email: " >"$wiz_tty"
    fi
    local em=""
    read -r em <"$wiz_tty" || true
    em="$(printf '%s' "$em" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
    [[ -z "$em" && -n "$em_default" ]] && em="$em_default"
    LIBRETIME_CERTBOT_EMAIL="$em"
    if [[ -z "$LIBRETIME_CERTBOT_EMAIL" ]]; then
      warning "Certbot email empty: will use --register-unsafely-without-email."
    elif [[ "$LIBRETIME_CERTBOT_EMAIL" != *@* ]]; then
      warning "email has no '@'; Let's Encrypt may reject it."
    fi
    info "HTTPS mode — public Nginx, Certbot, and (if Icecast is enabled) Icecast TLS will be configured."
  fi

  printf "\n%b\n" "${cyan}Optional: fail2ban protection${reset}"
  printf "Install LibreTime fail2ban filters and jails for:\n"
  printf "  - Harbor live inputs (ports 8001/8002)\n"
  printf "  - Icecast admin (ports 8000/8443)\n"
  printf "  - LibreTime web application login\n"
  printf "Policy: maxretry=5, findtime=3600 (1h), bantime=1800 (30 minutes).\n"
  local f2b_default="n"
  local f2b_hint="[y/N]"
  if [[ "${LIBRETIME_SETUP_FAIL2BAN:-false}" == "true" ]]; then
    f2b_default="y"
    f2b_hint="[Y/n]"
  fi
  local f2b=""
  while [[ ! "$f2b" =~ ^[yYnN]$ ]]; do
    printf "Enable fail2ban for LibreTime? %s: " "$f2b_hint" >"$wiz_tty"
    read -r f2b <"$wiz_tty" || true
    f2b="${f2b//[[:space:]]/}"
    [[ -z "$f2b" ]] && f2b="$f2b_default"
  done
  if [[ "$f2b" =~ ^[yY]$ ]]; then
    LIBRETIME_SETUP_FAIL2BAN=true
    info "fail2ban jails for LibreTime will be installed."
  else
    LIBRETIME_SETUP_FAIL2BAN=false
    info "fail2ban setup skipped (can be enabled later with --setup-fail2ban)."
  fi

  printf "\n%b\n" "${cyan}Summary:${reset}"
  printf "  Public URL:        ${yellow}%s${reset}\n" "$LIBRETIME_PUBLIC_URL"
  printf "  Internal app port: ${yellow}%s${reset} (traffic to local Nginx only)\n" "$LIBRETIME_LISTEN_PORT"
  if [[ "$mode" == "2" ]]; then
    printf "  Certbot email:     ${yellow}%s${reset}\n" "${LIBRETIME_CERTBOT_EMAIL:-<none>}"
    printf "  HTTPS automation:  ${yellow}%s${reset}\n" "$LIBRETIME_HTTPS_AUTO"
  fi
  printf "  fail2ban jails:    ${yellow}%s${reset}\n" "$LIBRETIME_SETUP_FAIL2BAN"
  printf "\n"
  local ok=""
  while [[ ! "$ok" =~ ^[yYnN]$ ]]; do
    printf "Continue with installation? [y/N]: " >"$wiz_tty"
    read -r ok <"$wiz_tty" || true
    ok="${ok//[[:space:]]/}"
    [[ -z "$ok" ]] && ok="n"
  done
  if [[ "$ok" =~ ^[nN]$ ]]; then
    info "installation cancelled."
    exit 0
  fi
  printf "\n"
}

# Load .env file if exists
[[ -f "$SCRIPT_DIR/.env" ]] && source "$SCRIPT_DIR/.env"

# Configuration
# > User used to run LibreTime.
LIBRETIME_USER=${LIBRETIME_USER:-"libretime"}
# > Listen port for LibreTime.
LIBRETIME_LISTEN_PORT=${LIBRETIME_LISTEN_PORT:-"8080"}
# > Public URL for LibreTime.
LIBRETIME_PUBLIC_URL=${LIBRETIME_PUBLIC_URL:-}
# > Timezone for LibreTime.
LIBRETIME_TIMEZONE=${LIBRETIME_TIMEZONE:-}
# > Storage path for LibreTime.
LIBRETIME_STORAGE_PATH=${LIBRETIME_STORAGE_PATH:-"/srv/libretime"}

# > Install LibreTime in editable mode.
# > Will keep working files in the project directory.
LIBRETIME_INSTALL_IN_PLACE=${LIBRETIME_INSTALL_IN_PLACE:-false}
# > Install a default icecast configuration.
LIBRETIME_SETUP_ICECAST=${LIBRETIME_SETUP_ICECAST:-true}
# > Create a default postgresql user with a random password.
LIBRETIME_SETUP_POSTGRESQL=${LIBRETIME_SETUP_POSTGRESQL:-true}
# > Create a default rabbitmq user with a random password.
LIBRETIME_SETUP_RABBITMQ=${LIBRETIME_SETUP_RABBITMQ:-true}
# > Install fail2ban filters/jails for Harbor, Icecast and LibreTime login.
# > Disabled by default; the wizard can enable it interactively.
LIBRETIME_SETUP_FAIL2BAN=${LIBRETIME_SETUP_FAIL2BAN:-false}

# > Comma separated list of sections to exclude from packages list.
LIBRETIME_PACKAGES_EXCLUDES=${LIBRETIME_PACKAGES_EXCLUDES:-}

# > If public_url is https://..., enable nginx reverse proxy on 80/443, Certbot, Icecast TLS.
LIBRETIME_HTTPS_AUTO=${LIBRETIME_HTTPS_AUTO:-true}
# > Email for Let's Encrypt account (recommended). If empty, Certbot uses --register-unsafely-without-email.
LIBRETIME_CERTBOT_EMAIL=${LIBRETIME_CERTBOT_EMAIL:-}
# > HTTPS listen port for Icecast (mount URLs use this port).
LIBRETIME_ICECAST_HTTPS_PORT=${LIBRETIME_ICECAST_HTTPS_PORT:-8443}
LIBRETIME_WIZARD=false

require_arg() {
  [[ $# -ge 2 ]] || error "option '$1' requires a value"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --user | -u)
      require_arg "$@"
      LIBRETIME_USER=$2
      shift 2
      ;;
    --listen-port | -p)
      require_arg "$@"
      LIBRETIME_LISTEN_PORT=$2
      shift 2
      ;;
    --storage-path | -s)
      require_arg "$@"
      LIBRETIME_STORAGE_PATH=$2
      shift 2
      ;;
    --in-place | -i)
      LIBRETIME_INSTALL_IN_PLACE=true
      shift 1
      ;;
    --update-nginx)
      error "the '--update-nginx' option was removed in 4.0.0"
      ;;
    --no-setup-icecast)
      LIBRETIME_SETUP_ICECAST=false
      shift 1
      ;;
    --no-setup-postgresql)
      LIBRETIME_SETUP_POSTGRESQL=false
      shift 1
      ;;
    --no-setup-rabbitmq)
      LIBRETIME_SETUP_RABBITMQ=false
      shift 1
      ;;
    --setup-fail2ban)
      LIBRETIME_SETUP_FAIL2BAN=true
      shift 1
      ;;
    --no-setup-fail2ban)
      LIBRETIME_SETUP_FAIL2BAN=false
      shift 1
      ;;
    --no-https-auto)
      LIBRETIME_HTTPS_AUTO=false
      shift 1
      ;;
    --wizard)
      LIBRETIME_WIZARD=true
      shift 1
      ;;
    --packages-excludes)
      require_arg "$@"
      LIBRETIME_PACKAGES_EXCLUDES=$2
      shift 2
      ;;
    --help | -h)
      usage
      exit 0
      ;;
    --version)
      version
      exit 0
      ;;
    -*)
      usage
      exit 1
      ;;
    *)
      LIBRETIME_PUBLIC_URL=$1
      shift 1
      ;;
  esac
done

if $LIBRETIME_WIZARD && [[ -n "${LIBRETIME_PUBLIC_URL:-}" ]]; then
  error "do not combine --wizard with a positional URL. Examples: $0 --wizard   or   $0 https://radio.example.org"
fi

# HTTPS hostname is computed after optional wizard (see Prepare section)
LIBRETIME_PUBLIC_HOSTNAME=""
LIBRETIME_HTTPS_ENABLE=false

# Variables
DEFAULT_WEB_USER="www-data"

# Paths
VENV_DIR="/opt/libretime"
CONFIG_DIR="/etc/libretime"
CONFIG_FILEPATH="$CONFIG_DIR/config.yml"
CONFIG_TMP_FILEPATH="$CONFIG_DIR/config.yml.tmp"
CONFIG_EXAMPLE_FILEPATH="$SCRIPT_DIR/installer/config.yml"
WORKING_DIR="/var/lib/libretime"
LOG_DIR="/var/log/libretime"
LEGACY_WEB_ROOT="/usr/share/libretime/legacy"

SERVICE_DIR="/usr/lib/systemd/system"

# command_exist <command>
command_exist() {
  command -v "$1" > /dev/null || error "$1 command not found!"
}

# generate_random_password
# Note: with `set -o pipefail`, `tr | head` is not safe -- when head closes
# after 32 bytes, tr gets SIGPIPE and may exit 141, failing the whole script
# in command substitution. Disable pipefail for this pipeline only.
generate_random_password() {
  ( set +o pipefail; tr -cd '[:alnum:]' < /dev/urandom | head -c32 )
}

# mkdir_and_chown <user> <path>
mkdir_and_chown() {
  mkdir -p "$2"
  chown -R "$1:$1" "$2"
}

# backup_if_exists <file>
backup_if_exists() {
  if [[ -f "$1" ]]; then
    backup="$1.$(date --iso-8601=seconds).bak"
    warning "found existing $1, creating a backup to $backup"
    mv "$1" "$backup"
  fi
}

# diff_if_exists <src> <dest>
diff_if_exists() {
  src="$1"
  dest="$2"
  shift 2

  if [[ -f "$dest" ]]; then
    src_explicit_filename="$(dirname "$src")/$(basename "$dest").new"
    cp "$src" "$src_explicit_filename"
    # print what the existing file $dest would become if $src is copied
    diff -u --color=always --ignore-trailing-space "$dest" "$src_explicit_filename" || :
    rm -f "$src_explicit_filename"
  fi
}

# cp_if_different <src> <dest>
cp_if_different() {
  if [[ -f "$2" ]] && diff -q "$1" "$2" > /dev/null; then
    return
  fi
  diff_if_exists "$1" "$2"
  backup_if_exists "$2"
  cp "$1" "$2"
}

# template_file <action> <src> <dest> <render...>
template_file() {
  action="$1"
  src="$2"
  dest="$3"
  shift 3

  tmp_file=$(mktemp)
  "$@" "$src" > "$tmp_file"
  $action "$tmp_file" "$dest"
  rm "$tmp_file"
}

# get_config <key...>
get_config() {
  query="/^${1}:/\n"
  while [[ $# -gt 1 ]]; do
    shift
    query+="/ \+${1}:/\n"
  done
  query+="q"

  echo -e "$query" | ed --quiet "$CONFIG_FILEPATH" |
    tail -n 2 |
    grep "$1" |
    awk -F ': ' '{ print $2 }'
}

# set_config <value> <key...>
set_config() {
  value="${1}" && shift

  query="/^${1}:/\n"
  while [[ $# -gt 1 ]]; do
    shift
    query+="/ \+${1}:/\n"
  done
  query+="s|\(${1}:\).*|\1 ${value}|\n"
  query+="wq"

  echo -e "$query" | ed --quiet "$CONFIG_TMP_FILEPATH" > /dev/null
}

# install_python_app <path>
install_python_app() {
  info "installing python app from $1"
  $VENV_DIR/bin/pip install --upgrade "$1"
}

# link_python_app <name>
link_python_app() {
  ln -s -f "$VENV_DIR/bin/$1" "/usr/local/bin/$1"
}

# install_service <name> <filepath>
#
# <filepath> has to be relative to the project root
install_service() {
  command_exist systemctl

  local service_name="$1"
  local service_src="$2"
  local service_dest="$SERVICE_DIR/$service_name"

  info "deploying $service_name service"

  [[ -f "$service_src" ]] || error "service '$service_name' src path '$service_src' does not exists!"

  if [[ ! -d "$SERVICE_DIR" ]]; then
    mkdir -p "$SERVICE_DIR"
  fi

  template_file cp_if_different "$service_src" "$service_dest" \
    sed \
      -e "s|^User=.*|User=${LIBRETIME_USER}|" \
      -e "s|^Group=.*|Group=${LIBRETIME_USER}|" \
      -e "s|@@DEFAULT_WEB_USER@@|${DEFAULT_WEB_USER}|g" \
      -e "s|@@VENV_DIR@@|${VENV_DIR}|g" \
      -e "s|@@CONFIG_DIR@@|${CONFIG_DIR}|g" \
      -e "s|@@CONFIG_FILEPATH@@|${CONFIG_FILEPATH}|g" \
      -e "s|@@LOG_DIR@@|${LOG_DIR}|g" \
      -e "s|@@WORKING_DIR@@|${WORKING_DIR}|g"

  chmod 0644 "$service_dest"
  chown root:root "$service_dest"
  systemctl enable "$service_name"
}

# service_restart_if_active <name>
service_restart_if_active() {
  if systemctl is-active "$1" > /dev/null; then
    info "restarting $1 service"
    systemctl restart "$1"
  fi
}

is_debian=false
distro="unknown"

check_distribution()  {
  local ID="unknown"
  local VERSION_ID="unknown"
  local VERSION_CODENAME="unknown"

  if [[ -f "/etc/os-release" ]]; then
    # shellcheck disable=SC1091
    source "/etc/os-release"
  fi

  # Minimal / testing installs: prefer VERSION_ID=13 or codename trixie
  # shellcheck disable=SC2034
  if [[ "$ID" == "debian" ]] && { [[ "${VERSION_ID:-}" == "13" ]] || [[ "${VERSION_CODENAME:-}" == "trixie" ]]; }; then
    is_debian=true && distro="trixie"
  else
    error "could not determine supported distribution (ID='$ID' VERSION_ID='${VERSION_ID:-}' CODENAME='${VERSION_CODENAME:-}')

LibreTime is supported only on Debian 13 (Trixie)."
  fi
}

ensure_local_hostname_resolution() {
  local host short_host hosts_line

  host="$(hostname 2>/dev/null || true)"
  [[ -n "$host" ]] || return 0
  short_host="${host%%.*}"

  # If hostname already resolves, do nothing.
  if command -v getent > /dev/null; then
    if getent hosts "$host" > /dev/null 2>&1; then
      return 0
    fi
    if [[ "$short_host" != "$host" ]] && getent hosts "$short_host" > /dev/null 2>&1; then
      return 0
    fi
  fi

  # Common Debian fix when sudo/apt warn "unable to resolve host".
  if [[ "$short_host" == "$host" ]]; then
    hosts_line="127.0.1.1 ${host}"
  else
    hosts_line="127.0.1.1 ${host} ${short_host}"
  fi

  if [[ -f /etc/hosts ]] && grep -Fq "$hosts_line" /etc/hosts; then
    return 0
  fi

  warning "local hostname '$host' is not resolvable; appending '$hosts_line' to /etc/hosts"
  printf "\n%s\n" "$hosts_line" >> /etc/hosts
}

# list_packages <packages_file>
list_packages() {
  extra_args=()
  for section in $LIBRETIME_PACKAGES_EXCLUDES; do
    extra_args+=("--exclude=$section")
  done

  python3 "$SCRIPT_DIR/tools/packages.py" \
    "$distro" \
    "$1" \
    --format=line \
    "${extra_args[@]}"
}

prepare_packages_install() {
  if $is_debian; then
    DEBIAN_FRONTEND=noninteractive apt-get -q update
  fi
}

# install_packages <packages...>
# Use -q (not -qq): very-quiet apt looks like a hang; -q still keeps noise low
# but shows unpack/config lines so long installs are visibly progressing.
install_packages() {
  if $is_debian; then
    # shellcheck disable=SC2086
    DEBIAN_FRONTEND=noninteractive apt-get -q -y install "$@"
  else
    warning "installing dependencies is not supported for this distribution"
  fi
}

# get_system_timezone
get_system_timezone() {
  if ! command -v timedatectl > /dev/null; then
    return
  fi

  timezone="$(timedatectl show --property=Timezone --value)"
  if [[ -n "$timezone" && ! "$timezone" =~ UTC$ ]]; then
    echo "$timezone"
  fi
}

load_config_defaults() {
  if [[ -z "$LIBRETIME_TIMEZONE" ]]; then
    LIBRETIME_TIMEZONE="$(get_system_timezone)"
  fi
}

# Prepare
########################################################################################

# Make sure only root can run our script
(($( id -u) == 0))  || error "this script must be run as root!"

banner
check_distribution
ensure_local_hostname_resolution

load_config_defaults

is_first_install=true
if [[ -f "$CONFIG_FILEPATH" ]]; then
  is_first_install=false
  warning "a configuration file already exists at $CONFIG_FILEPATH, only running upgrade steps!"
fi

if $LIBRETIME_WIZARD && ! $is_first_install; then
  error "--wizard is only for the first install. To upgrade, run $0 without --wizard (same arguments as the original install) or edit $CONFIG_FILEPATH."
fi

# ---------------------------------------------------------------------------
# Upgrade mode: rehydrate vars from config.yml, hard-error on incompatible
# flag changes, and warn the user about risky options. Passwords, database,
# Icecast XML and first-install bootstrap steps are never touched here.
# ---------------------------------------------------------------------------
if ! $is_first_install; then
  # Rehydrate LIBRETIME_PUBLIC_URL from config.yml when the user did not pass
  # it on the command line. Downstream logic (HTTPS detection, fail2ban jail
  # ports and log path) then stays aligned with the installed system even
  # when the operator just runs `./install` with no positional URL.
  detected_public_url="$(get_config general public_url)"
  if [[ -z "${LIBRETIME_PUBLIC_URL:-}" ]]; then
    if [[ -n "$detected_public_url" ]]; then
      LIBRETIME_PUBLIC_URL="$detected_public_url"
      info "rehydrated public_url from $CONFIG_FILEPATH: $LIBRETIME_PUBLIC_URL"
    fi
  elif [[ -n "$detected_public_url" && "$LIBRETIME_PUBLIC_URL" != "$detected_public_url" ]]; then
    # Block silent drift: a positional URL different from config.yml would
    # skew downstream logic (HTTPS detection, fail2ban jail) while config.yml
    # keeps the old value, and the two would diverge without warning.
    error "public_url mismatch: argument '$LIBRETIME_PUBLIC_URL' differs from '$CONFIG_FILEPATH' value '$detected_public_url'. To change the public URL, edit $CONFIG_FILEPATH manually; to keep the current one, omit the positional URL."
  fi

  detected_user="$(stat -c '%U' "$CONFIG_FILEPATH" 2>/dev/null || true)"
  detected_storage_path="$(get_config storage path)"
  detected_listen_port=""
  if [[ -f /etc/nginx/sites-available/libretime.conf ]]; then
    # grep exits 1 when there is no match; with `pipefail` that would kill the
    # install before we print the upgrade summary unless we only read pipeline status
    # from the last command (or disable pipefail for this sub-pipeline).
    detected_listen_port="$(
      set +o pipefail
      grep -oE 'listen[[:space:]]+[0-9]+' /etc/nginx/sites-available/libretime.conf | head -n1 | awk '{print $2}'
    )"
  fi
  detected_https_mode="no"
  if [[ -f /etc/nginx/sites-enabled/libretime-https-proxy.conf ]]; then
    detected_https_mode="proxy only (no TLS cert)"
    if [[ "$LIBRETIME_PUBLIC_URL" =~ ^https://([^/:?#]+) ]] \
       && [[ -f "/etc/letsencrypt/live/${BASH_REMATCH[1]}/fullchain.pem" ]]; then
      detected_https_mode="yes (TLS cert present)"
    fi
  fi
  detected_fail2ban="no"
  [[ -f /etc/fail2ban/jail.d/91-libretime.conf ]] && detected_fail2ban="yes"

  # Hard-error on incompatible user change: DB ownership in config.yml would
  # not match filesystem ownership, services would start but fail silently.
  if [[ -n "$detected_user" && "$detected_user" != "$LIBRETIME_USER" ]]; then
    error "configuration mismatch: --user '$LIBRETIME_USER' differs from the user owning '$CONFIG_FILEPATH' ('$detected_user'). Re-run with: --user $detected_user (or change the LibreTime system user manually: chown files, re-grant DB ownership, restart services)."
  fi

  printf "\n%b\n" "${yellow}== Upgrade mode — existing LibreTime install detected ==${reset}"
  printf "Passwords, database, Icecast XML and HTTPS/UFW bootstrap are NOT re-run.\n"
  printf "Application code, Nginx site config, systemd units and opt-in features (fail2ban) ARE updated.\n"
  printf "\n"
  printf "  ${cyan}Detected configuration:${reset}\n"
  printf "    System user:   ${yellow}%s${reset}\n" "${detected_user:-<unknown>}"
  printf "    Storage path:  ${yellow}%s${reset}\n" "${detected_storage_path:-<unknown>}"
  printf "    Public URL:    ${yellow}%s${reset}\n" "${LIBRETIME_PUBLIC_URL:-<none>}"
  printf "    Listen port:   ${yellow}%s${reset}\n" "${detected_listen_port:-<unknown>}"
  printf "    HTTPS proxy:   ${yellow}%s${reset}\n" "$detected_https_mode"
  printf "    fail2ban jail: ${yellow}%s${reset}\n" "$detected_fail2ban"
  printf "\n"
  printf "  ${cyan}Recommended:${reset} re-use the SAME flags used at first install.\n"
  printf "  ${cyan}Risky changes on upgrade:${reset}\n"
  printf "    ${yellow}--listen-port PORT${reset}   Nginx/proxy/config.yml port drift; UFW may block the new port.\n"
  printf "    ${yellow}--in-place${reset}           legacy web root path changes; Nginx will point to the current script dir.\n"
  printf "    ${yellow}--packages-excludes${reset}  skips apt upgrades of runtime deps (Liquidsoap, PHP, Python libs).\n"
  printf "  To CHANGE the LibreTime configuration, edit ${yellow}%s${reset} manually.\n" "$CONFIG_FILEPATH"
  printf "\n"
  if [[ -t 0 ]]; then
    printf "Proceeding in ${yellow}5${reset} seconds — press ${yellow}Ctrl+C${reset} to abort...\n"
    sleep 5 || true
  else
    info "non-interactive stdin detected — proceeding immediately."
  fi
  printf "\n"
fi

if $is_first_install && ! $LIBRETIME_WIZARD && [[ -z "${LIBRETIME_PUBLIC_URL:-}" ]]; then
  error "first install requires a public URL or --wizard. Examples:
  $0 http://192.168.1.10:8080
  $0 https://radio.example.org
  $0 --wizard"
fi

if $LIBRETIME_WIZARD; then
  run_install_wizard
fi

# Hostname for HTTPS automation (only when public_url is https://…)
if $LIBRETIME_HTTPS_AUTO && [[ -n "${LIBRETIME_PUBLIC_URL:-}" ]] && [[ "${LIBRETIME_PUBLIC_URL}" =~ ^https://([^/:?#]+) ]]; then
  LIBRETIME_PUBLIC_HOSTNAME="${BASH_REMATCH[1]}"
  LIBRETIME_HTTPS_ENABLE=true
fi

section "Prepare"

prepare_packages_install

install_packages sudo git make ed curl ca-certificates python3
make VERSION

info "creating project user"
if ! id "$LIBRETIME_USER" &> /dev/null; then
  useradd --no-create-home --home-dir "$WORKING_DIR" "$LIBRETIME_USER"
fi

info "creating project directories"
mkdir -p "$CONFIG_DIR"
mkdir_and_chown "$LIBRETIME_USER" "$WORKING_DIR"
mkdir_and_chown "$LIBRETIME_USER" "$LOG_DIR"

if $is_first_install; then
  [[ -f "$CONFIG_TMP_FILEPATH" ]] || cp "$CONFIG_EXAMPLE_FILEPATH" "$CONFIG_TMP_FILEPATH"
  chown "$LIBRETIME_USER:$LIBRETIME_USER" "$CONFIG_TMP_FILEPATH"
  chmod 640 "$CONFIG_TMP_FILEPATH"

  if [[ -n "$LIBRETIME_PUBLIC_URL" ]]; then
    set_config "$LIBRETIME_PUBLIC_URL" general public_url
  fi
  set_config "$(generate_random_password)" general api_key

  set_config "$(generate_random_password)" general secret_key

  if [[ -n "$LIBRETIME_TIMEZONE" ]]; then
    set_config "$LIBRETIME_TIMEZONE"  general timezone
  fi

  mkdir_and_chown "$LIBRETIME_USER" "$LIBRETIME_STORAGE_PATH"
  set_config "$LIBRETIME_STORAGE_PATH" storage path
else
  if [[ "$LIBRETIME_STORAGE_PATH" != "$(get_config storage path)" ]]; then
    error \
      "configuration mismatch between" \
      "the installer storage path option ('$LIBRETIME_STORAGE_PATH') and" \
      "the configuration file 'storage.path' field ('$(get_config storage path)')"
  fi
fi

# PostgreSQL
########################################################################################

# > LibreTime PostgreSQL user
LIBRETIME_POSTGRESQL_USER=${LIBRETIME_POSTGRESQL_USER:-"libretime"}
# > LibreTime PostgreSQL user password
LIBRETIME_POSTGRESQL_PASSWORD=${LIBRETIME_POSTGRESQL_PASSWORD:-$(generate_random_password)}
# > LibreTime PostgreSQL database
LIBRETIME_POSTGRESQL_DATABASE=${LIBRETIME_POSTGRESQL_DATABASE:-"libretime"}

if $LIBRETIME_SETUP_POSTGRESQL; then
  section "PostgreSQL"
  info "installing PostgreSQL packages via apt (if this sits with no new lines, another apt may hold the dpkg lock: fuser -v /var/lib/dpkg/lock-frontend)"
  install_packages postgresql postgresql-client

  # Ensure the server is up before any psql — otherwise the next pipeline can
  # block indefinitely (no output after the 'PostgreSQL' section header).
  info "starting PostgreSQL service (cluster may be created on first install)"
  systemctl enable --now postgresql 2>/dev/null || systemctl start postgresql 2>/dev/null || true
  if ! systemctl is-active --quiet postgresql 2>/dev/null; then
    shopt -s nullglob
    for unit in /lib/systemd/system/postgresql@*.service; do
      systemctl enable --now "$(basename "$unit")" 2>/dev/null || systemctl start "$(basename "$unit")" 2>/dev/null || true
    done
    shopt -u nullglob
  fi
  if command -v pg_isready >/dev/null 2>&1; then
    info "waiting for PostgreSQL to accept connections…"
    for ((i = 0; i < 120; i++)); do
      if sudo -iH -u postgres pg_isready -q; then
        break
      fi
      if ((i % 20 == 0)) && ((i > 0)); then
        info "still waiting for PostgreSQL (${i}s) — check: systemctl status postgresql; journalctl -n 20 -u postgresql"
      fi
      sleep 1
    done
    if ! sudo -iH -u postgres pg_isready -q; then
      error "PostgreSQL did not become ready after 120s. On the server run: systemctl status postgresql; journalctl -xeu postgresql"
    fi
  else
    warning "pg_isready not found; if the next step hangs, PostgreSQL is not listening — check systemctl status postgresql"
  fi

  if $is_first_install; then
    # Idempotent: whether the role is brand new (success-path) or already
    # exists from an aborted first install (retry-path), always ALTER ROLE
    # with the password we generate/keep and write it to config.yml.tmp.
    # This prevents a silent password mismatch between DB and config.yml.
    info "configuring database role and schema for LibreTime"
    if ! sudo -iH -u postgres psql --csv --tuples-only --command='\du' | grep -qw "^$LIBRETIME_POSTGRESQL_USER"; then
      info "creating PostgreSQL user '$LIBRETIME_POSTGRESQL_USER'"
      sudo -iH -u postgres createuser "$LIBRETIME_POSTGRESQL_USER"
    else
      warning "PostgreSQL user '$LIBRETIME_POSTGRESQL_USER' already exists — resetting password to keep config.yml in sync (likely a retry after a failed first install)."
    fi
    sudo -iH -u postgres psql -c "ALTER ROLE $LIBRETIME_POSTGRESQL_USER WITH PASSWORD '$LIBRETIME_POSTGRESQL_PASSWORD';"
    set_config "$LIBRETIME_POSTGRESQL_USER" database user
    set_config "$LIBRETIME_POSTGRESQL_PASSWORD" database password

    if ! sudo -iH -u postgres psql --csv --tuples-only --list | grep -qw "^$LIBRETIME_POSTGRESQL_DATABASE"; then
      info "creating PostgreSQL database '$LIBRETIME_POSTGRESQL_DATABASE' with owner '$LIBRETIME_POSTGRESQL_USER'"
      sudo -iH -u postgres createdb --template=template0 --encoding=UTF-8 --owner="$LIBRETIME_POSTGRESQL_USER" "$LIBRETIME_POSTGRESQL_DATABASE"
    else
      warning "PostgreSQL database '$LIBRETIME_POSTGRESQL_DATABASE' already exists — keeping existing data (retry-safe)."
    fi
    set_config "$LIBRETIME_POSTGRESQL_DATABASE" database name
  fi
fi

# RabbitMQ
########################################################################################

# > LibreTime RabbitMQ user
LIBRETIME_RABBITMQ_USER=${LIBRETIME_RABBITMQ_USER:-"libretime"}
# > LibreTime RabbitMQ user password
LIBRETIME_RABBITMQ_PASSWORD=${LIBRETIME_RABBITMQ_PASSWORD:-$(generate_random_password)}
# > LibreTime RabbitMQ vhost
LIBRETIME_RABBITMQ_VHOST=${LIBRETIME_RABBITMQ_VHOST:-"/libretime"}

if $LIBRETIME_SETUP_RABBITMQ; then
  section "RabbitMQ"
  install_packages rabbitmq-server

  if $is_first_install; then
    # Idempotent: if the user exists (retry-path), reset the password with
    # change_password so config.yml and RabbitMQ stay in sync.
    if ! rabbitmqctl --quiet list_users | grep -qw "^$LIBRETIME_RABBITMQ_USER"; then
      info "creating RabbitMQ user '$LIBRETIME_RABBITMQ_USER'"
      rabbitmqctl add_user "$LIBRETIME_RABBITMQ_USER" "$LIBRETIME_RABBITMQ_PASSWORD"
    else
      warning "RabbitMQ user '$LIBRETIME_RABBITMQ_USER' already exists — resetting password to keep config.yml in sync (likely a retry after a failed first install)."
      rabbitmqctl change_password "$LIBRETIME_RABBITMQ_USER" "$LIBRETIME_RABBITMQ_PASSWORD"
    fi
    set_config "$LIBRETIME_RABBITMQ_USER" rabbitmq user
    set_config "$LIBRETIME_RABBITMQ_PASSWORD" rabbitmq password

    if ! rabbitmqctl --quiet list_vhosts | grep -qw "^$LIBRETIME_RABBITMQ_VHOST"; then
      info "creating RabbitMQ vhost '$LIBRETIME_RABBITMQ_VHOST' with owner '$LIBRETIME_RABBITMQ_USER'"
      rabbitmqctl add_vhost "$LIBRETIME_RABBITMQ_VHOST"
    else
      warning "RabbitMQ vhost '$LIBRETIME_RABBITMQ_VHOST' already exists — ensuring permissions for '$LIBRETIME_RABBITMQ_USER'."
    fi
    # Permissions are idempotent: safe to re-apply on both new and existing vhosts.
    rabbitmqctl set_permissions -p "$LIBRETIME_RABBITMQ_VHOST" "$LIBRETIME_RABBITMQ_USER" '.*' '.*' '.*'
    set_config "$LIBRETIME_RABBITMQ_VHOST" rabbitmq vhost
  fi
fi

# Icecast
########################################################################################

# > LibreTime Icecast admin password
LIBRETIME_ICECAST_ADMIN_PASSWORD=${LIBRETIME_ICECAST_ADMIN_PASSWORD:-$(generate_random_password)}
# > LibreTime Icecast source password
LIBRETIME_ICECAST_SOURCE_PASSWORD=${LIBRETIME_ICECAST_SOURCE_PASSWORD:-$(generate_random_password)}
# > LibreTime Icecast relay password
LIBRETIME_ICECAST_RELAY_PASSWORD=${LIBRETIME_ICECAST_RELAY_PASSWORD:-$(generate_random_password)}

if $LIBRETIME_SETUP_ICECAST; then
  section "Icecast"
  install_packages icecast2
  systemctl enable icecast2

  systemctl start icecast2

  if $is_first_install; then
    icecast_config_filepath="/etc/icecast2/icecast.xml"

    cp_if_different \
      "${SCRIPT_DIR}/installer/icecast/icecast.xml" \
      "$icecast_config_filepath"

    sed --in-place \
      -e "s|<admin-password>[^<]*</admin-password>|<admin-password>${LIBRETIME_ICECAST_ADMIN_PASSWORD}</admin-password>|" \
      -e "s|<source-password>[^<]*</source-password>|<source-password>${LIBRETIME_ICECAST_SOURCE_PASSWORD}</source-password>|" \
      -e "s|<relay-password>[^<]*</relay-password>|<relay-password>${LIBRETIME_ICECAST_RELAY_PASSWORD}</relay-password>|" \
      "$icecast_config_filepath"

    service_restart_if_active icecast2

    set_config "$LIBRETIME_ICECAST_ADMIN_PASSWORD" stream outputs .default_icecast_output admin_password
    set_config "$LIBRETIME_ICECAST_SOURCE_PASSWORD" stream outputs .default_icecast_output source_password
  fi
fi

