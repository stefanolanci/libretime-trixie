# HTTPS: reverse proxy, Certbot, Icecast TLS (first install only, when public_url is https://…)
########################################################################################

if $is_first_install && $LIBRETIME_HTTPS_ENABLE; then
  section "HTTPS (Nginx, Let's Encrypt, Icecast)"

  command_exist nginx

  info "installing Certbot and the Nginx plugin"
  install_packages certbot python3-certbot-nginx

  if command -v ufw > /dev/null 2>&1 && ufw status 2> /dev/null | grep -q "Status: active"; then
    info "UFW is active: allowing 80/tcp and 443/tcp for the web UI and ACME"
    ufw allow 80/tcp
    ufw allow 443/tcp
    if $LIBRETIME_SETUP_ICECAST; then
      info "UFW: allowing ${LIBRETIME_ICECAST_HTTPS_PORT}/tcp for Icecast HTTPS listeners"
      ufw allow "${LIBRETIME_ICECAST_HTTPS_PORT}"/tcp
    fi
  fi

  PROXY_AVAIL="/etc/nginx/sites-available/libretime-https-proxy.conf"
  PROXY_ENABLED="/etc/nginx/sites-enabled/libretime-https-proxy.conf"

  template_file cp_if_different \
    "${SCRIPT_DIR}/installer/nginx/libretime-https-proxy.conf" \
    "$PROXY_AVAIL" \
    sed \
    -e "s|@@SERVER_NAME@@|${LIBRETIME_PUBLIC_HOSTNAME}|g" \
    -e "s|@@UPSTREAM_PORT@@|${LIBRETIME_LISTEN_PORT}|g"

  ln -sf "$PROXY_AVAIL" "$PROXY_ENABLED"

  info "testing and reloading nginx before the certificate request"
  nginx -t
  systemctl reload nginx

  certbot_opts=(
    "--nginx"
    "-d" "$LIBRETIME_PUBLIC_HOSTNAME"
    "--non-interactive"
    "--agree-tos"
    "--redirect"
  )
  if [[ -n "$LIBRETIME_CERTBOT_EMAIL" ]]; then
    certbot_opts+=("--email" "$LIBRETIME_CERTBOT_EMAIL")
  else
    certbot_opts+=("--register-unsafely-without-email")
  fi

  if certbot "${certbot_opts[@]}"; then
    info "TLS certificate issued for '${LIBRETIME_PUBLIC_HOSTNAME}'"
    LIVE="/etc/letsencrypt/live/${LIBRETIME_PUBLIC_HOSTNAME}"
    if $LIBRETIME_SETUP_ICECAST && [[ -f "$LIVE/fullchain.pem" && -f "$LIVE/privkey.pem" ]]; then
      tmp_bundle="$(mktemp)"
      cat "$LIVE/fullchain.pem" "$LIVE/privkey.pem" > "$tmp_bundle"
      install --group=icecast --mode=640 "$tmp_bundle" /etc/icecast2/bundle.pem
      rm -f "$tmp_bundle"

      if python3 "${SCRIPT_DIR}/installer/icecast/patch_xml_ssl.py" \
        /etc/icecast2/icecast.xml \
        "$LIBRETIME_PUBLIC_HOSTNAME" \
        "$LIBRETIME_ICECAST_HTTPS_PORT"; then
        service_restart_if_active icecast2
        install -m 0755 "${SCRIPT_DIR}/installer/letsencrypt/renew-icecast-bundle.sh" \
          "/usr/local/sbin/libretime-le-icecast-bundle.sh"
        ln -sf "/usr/local/sbin/libretime-le-icecast-bundle.sh" \
          "/etc/letsencrypt/renewal-hooks/deploy/50-libretime-icecast-bundle.sh"
        info "Icecast TLS enabled on port ${LIBRETIME_ICECAST_HTTPS_PORT} (bundle: /etc/icecast2/bundle.pem)"
      else
        warning "could not patch icecast.xml for TLS; configure Icecast SSL manually"
      fi

      if python3 "${SCRIPT_DIR}/installer/config/patch_icecast_public_urls.py" \
        "$CONFIG_TMP_FILEPATH" \
        "$LIBRETIME_PUBLIC_HOSTNAME" \
        "$LIBRETIME_ICECAST_HTTPS_PORT"; then
        info "updated stream.outputs.icecast public_url fields for HTTPS listening"
      else
        warning "could not set Icecast public_url in config.yml; edit ${CONFIG_TMP_FILEPATH} manually"
      fi
    elif ! $LIBRETIME_SETUP_ICECAST; then
      info "skipping Icecast TLS (LibreTime was installed with --no-setup-icecast)"
    fi
  else
    warning "Certbot failed. Check DNS for '${LIBRETIME_PUBLIC_HOSTNAME}', firewall (80/443), then run:"
    warning "  certbot --nginx -d '${LIBRETIME_PUBLIC_HOSTNAME}'"
  fi
fi

# UFW baseline rules for first install (both HTTP and HTTPS modes)
########################################################################################

if $is_first_install && command -v ufw > /dev/null 2>&1 && ufw status 2> /dev/null | grep -q "Status: active"; then
  if ! $LIBRETIME_HTTPS_ENABLE; then
    info "UFW is active: allowing ${LIBRETIME_LISTEN_PORT}/tcp for the web UI"
    ufw allow "${LIBRETIME_LISTEN_PORT}"/tcp
  fi

  if $LIBRETIME_SETUP_ICECAST; then
    info "UFW: allowing 8000/tcp for Icecast HTTP streams"
    ufw allow 8000/tcp
    info "UFW: allowing 8001/tcp and 8002/tcp for Harbor live inputs"
    ufw allow 8001/tcp
    ufw allow 8002/tcp
  fi
fi

# fail2ban jails for LibreTime (opt-in)
########################################################################################

if $LIBRETIME_SETUP_FAIL2BAN; then
  section "fail2ban"

  install_packages fail2ban

  info "installing LibreTime fail2ban filters"
  install -m 0644 -D -t /etc/fail2ban/filter.d/ \
    "$SCRIPT_DIR/installer/fail2ban/filter.d/libretime-harbor.conf" \
    "$SCRIPT_DIR/installer/fail2ban/filter.d/icecast-auth.conf" \
    "$SCRIPT_DIR/installer/fail2ban/filter.d/nginx-libretime-login.conf"

  info "installing LibreTime fail2ban actions"
  install -m 0644 -D -t /etc/fail2ban/action.d/ \
    "$SCRIPT_DIR/installer/fail2ban/action.d/libretime-conntrack-flush.conf"

  # Harbor auth log written by Liquidsoap (ls_script.liq file.write).
  # Directory must exist and be writable by the libretime user before the
  # playout service starts; the file itself is touched 0640 so fail2ban can
  # register the jail even if no auth attempt has happened yet.
  install -d -m 0750 -o "$LIBRETIME_USER" -g adm /var/log/libretime
  install -m 0640 -o "$LIBRETIME_USER" -g adm -D /dev/null /var/log/libretime/harbor-auth.log 2>/dev/null || \
    touch /var/log/libretime/harbor-auth.log

  info "installing logrotate entry for /var/log/libretime/harbor-auth.log"
  sed "s|@@USER@@|$LIBRETIME_USER|g" \
    "$SCRIPT_DIR/installer/fail2ban/logrotate/libretime-harbor-auth.conf" \
    > /etc/logrotate.d/libretime-harbor-auth
  chmod 0644 /etc/logrotate.d/libretime-harbor-auth

  if $LIBRETIME_HTTPS_ENABLE; then
    # Reverse-proxy mode: nginx is publicly exposed on 80 (HTTP → HTTPS
    # redirect) and 443 (TLS). LIBRETIME_LISTEN_PORT is only the internal
    # upstream port in this mode and is not reachable from the outside.
    libretime_nginx_access_log="/var/log/nginx/libretime-proxy.access.log"
    libretime_nginx_ports="80,443"
  else
    # HTTP mode: nginx listens directly on LIBRETIME_LISTEN_PORT (default 8080,
    # overridable via --listen-port / LIBRETIME_LISTEN_PORT). The fail2ban jail
    # must target the same port, otherwise bans would not cover the real
    # service socket.
    libretime_nginx_access_log="/var/log/nginx/libretime.access.log"
    libretime_nginx_ports="${LIBRETIME_LISTEN_PORT}"
  fi
  # Ensure the log file exists so fail2ban does not fail the jail at startup
  # when nginx has not written any request yet.
  install -m 0640 -o www-data -g adm -D /dev/null "$libretime_nginx_access_log" 2>/dev/null || \
    touch "$libretime_nginx_access_log"

  # If nginx is already running it still holds an fd on the previous (now unlinked)
  # inode of the access log; without a reopen it would keep writing to the orphan
  # file and the nginx-libretime-login jail would never see any request.
  if systemctl is-active nginx > /dev/null 2>&1; then
    nginx -t > /dev/null 2>&1 && systemctl reload nginx > /dev/null 2>&1 || true
  fi

  info "installing LibreTime fail2ban jail drop-in (nginx log: $libretime_nginx_access_log, nginx ports: $libretime_nginx_ports)"
  sed -e "s|@LIBRETIME_NGINX_ACCESS_LOG@|$libretime_nginx_access_log|g" \
      -e "s|@LIBRETIME_NGINX_PORTS@|$libretime_nginx_ports|g" \
    "$SCRIPT_DIR/installer/fail2ban/jail.d/91-libretime.conf" \
    > "/etc/fail2ban/jail.d/91-libretime.conf"
  chmod 0644 "/etc/fail2ban/jail.d/91-libretime.conf"

  systemctl enable fail2ban > /dev/null 2>&1 || true
  if systemctl is-active fail2ban > /dev/null 2>&1; then
    info "reloading fail2ban"
    fail2ban-client reload > /dev/null || service_restart_if_active fail2ban
  else
    info "starting fail2ban"
    systemctl start fail2ban || warning "could not start fail2ban; check 'systemctl status fail2ban'"
  fi
fi

# Finalize
########################################################################################

if $is_first_install; then
  section "Finalize"
  info "moving config file in place"
  mv "$CONFIG_TMP_FILEPATH" "$CONFIG_FILEPATH"
fi

# Services
########################################################################################

section "Services"

install_service "libretime.target" "$SCRIPT_DIR/installer/systemd/libretime.target"

systemctl daemon-reload

systemctl enable nginx
systemctl enable "php${PHP_VERSION}-fpm"

service_restart_if_active "php$PHP_VERSION-fpm"
service_restart_if_active "nginx"

# On upgrade, the Python venv has just been rebuilt and systemd units may have
# been rewritten. Running services still hold references to the old code until
# restarted, which is a common "upgrade did nothing" footgun. We restart the
# already-active services only (never auto-start on first install — the admin
# must migrate the DB first).
if ! $is_first_install; then
  info "restarting already-active LibreTime services"
  for svc in libretime-api libretime-playout libretime-liquidsoap \
             libretime-analyzer libretime-worker; do
    service_restart_if_active "$svc"
  done
fi

# Instructions
########################################################################################

if $is_first_install; then
  section "Instructions"
  printf "
${yellow}\
To finalize the installation process, start by editing your configuration file $CONFIG_FILEPATH.

Once configured, run the following command to setup the database:

${cyan}\
$ sudo -u $LIBRETIME_USER libretime-api migrate

${yellow}\
Finally, start LibreTime using the following command:

${cyan}\
$ sudo systemctl start libretime.target

${reset}"

  if $LIBRETIME_HTTPS_ENABLE; then
    printf "
${yellow}\
HTTPS was requested (public_url starts with https://). If Certbot succeeded, the web UI is
reachable over TLS. Ensure DNS for '${LIBRETIME_PUBLIC_HOSTNAME}' points to this server before
installing. If you use UFW, open port 8000/tcp as well for Icecast HTTP streams (and harbor
ports if needed). Icecast HTTPS listens on port ${LIBRETIME_ICECAST_HTTPS_PORT} when Icecast
TLS was configured.

${reset}"
  fi

else
  printf "
${yellow}\
Once upgraded, run the following command to migrate the database:

${cyan}\
$ sudo -u $LIBRETIME_USER libretime-api migrate

${yellow}\
You can restart LibreTime using the following command:

${cyan}\
$ sudo systemctl restart libretime.target

${reset}"
fi
